<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Ana uygulama ile aynı App Group — widget + Live Activity paylaşımlı
	     UserDefaults okur. (Portal'da com.adenababy.adenaBaby.FeedWidget App ID'ine
	     bu grup ilişkilendirildi, 2026-06-22.) -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.adenababy.adenaBaby</string>
	</array>
</dict>
</plist>
