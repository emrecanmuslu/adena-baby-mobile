<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- TestFlight/App Store dağıtımı production APNs ortamı kullanır. Tek build
	     hattımız CI → TestFlight olduğu için production. (Yerel debug/sideload
	     bırakıldı; gerekirse development'a çevrilir.) -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Widget + Live Activity ile ana uygulama arası paylaşımlı depolama. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.adenababy.adenaBaby</string>
	</array>
	<!-- Apple ile Giriş (App ID'de capability açık; sign_in_with_apple plugin). -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
